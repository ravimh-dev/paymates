<%- include('../partials/page-head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>

  <div class="main-area">
    <main class="main-content main-content--wide">
      <div class="page-hero">
        <div>
          <p class="page-kicker">Activity</p>
          <h1 class="page-title">History</h1>
          <p class="page-sub">Filter settlements across your groups.</p>
        </div>
      </div>

      <section class="card card--soft">
        <div class="filter-row">
          <select id="historyTypeFilter" class="form-input">
            <option value="all">All types</option>
            <option value="settlement">Settlements</option>
          </select>
          <select id="historyGroupFilter" class="form-input">
            <option value="all">All groups</option>
          </select>
        </div>
      </section>

      <section id="historyList" class="stack-list"></section>
    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<script src="/js/app.js"></script>
<script src="/js/history.js"></script>
</body>
</html>
