<%- include('../partials/page-head') %>
<div class="auth-shell auth-shell--single">
  <section class="auth-hero">
    <div class="auth-brand-mark">ES</div>
    <h1>Reset your password.</h1>
    <p>Use the token from your email to set a new password.</p>
  </section>

  <section class="auth-panel">
    <div class="auth-card">
      <div class="auth-card__header">
        <h2>Reset password</h2>
        <p>Enter the token and your new password.</p>
      </div>
      <div id="resetError" class="alert alert-error hidden"></div>
      <div id="resetSuccess" class="alert alert-success hidden"></div>
      <form id="resetPasswordForm" class="auth-form">
        <div class="form-group">
          <label class="form-label">Token</label>
          <input class="form-input" type="text" name="token" id="resetToken" required />
        </div>
        <div class="form-group">
          <label class="form-label">New Password</label>
          <input class="form-input" type="password" name="password" required />
        </div>
        <button class="btn btn-primary full-width" type="submit">Reset password</button>
      </form>
      <div class="auth-divider"></div>
      <a href="/login" class="btn btn-ghost full-width">Back to login</a>
    </div>
  </section>
</div>

<script src="/js/app.js"></script>
<script src="/js/reset-password.js"></script>
</body>
</html>
