<%- include('../partials/page-head') %>
<div class="auth-shell auth-shell--single">
  <section class="auth-hero">
    <div class="auth-brand-mark">ES</div>
    <h1>Join your group.</h1>
    <p>This invite link will add you to the group after you log in.</p>
  </section>

  <section class="auth-panel">
    <div class="auth-card">
      <div class="auth-card__header">
        <h2>Invite token</h2>
        <p id="inviteHint">Preparing your invite...</p>
      </div>
      <div id="joinError" class="alert alert-error hidden"></div>
      <div id="joinSuccess" class="alert alert-success hidden"></div>
      <button type="button" class="btn btn-primary full-width" id="joinGroupBtn">Join group now</button>
      <div class="auth-divider"></div>
      <a href="/dashboard" class="btn btn-ghost full-width">Go to dashboard</a>
    </div>
  </section>
</div>

<script>
  window.__inviteToken = "<%= inviteToken %>";
</script>
<script src="/js/app.js"></script>
<script src="/js/join.js"></script>
</body>
</html>
