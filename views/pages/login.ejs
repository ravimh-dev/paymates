<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login · Expense Splitter</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body class="auth-body">
  <div class="auth-shell">
    <section class="auth-hero">
      <div class="auth-brand-mark">ES</div>
      <h1>Split expenses without the friction.</h1>
      <p>Track groups, expenses, balances, and settlements in a clean workspace built for fast decisions.</p>
      <div class="health-pill" id="serverStatus">Checking server status...</div>
      <ul class="auth-points">
        <li>Sidebar-driven group navigation</li>
        <li>One-click settlement planning</li>
        <li>Equal, percentage, and custom splits</li>
      </ul>
    </section>

    <section class="auth-panel">
      <div class="auth-card">
        <div class="auth-card__header">
          <h2>Sign in</h2>
          <p>Welcome back. Continue where you left off.</p>
        </div>
        <div id="authError" class="alert alert-error hidden"></div>
        <form id="loginForm" class="auth-form">
          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="password">Password</label>
            <input class="form-input" type="password" id="password" name="password" placeholder="••••••••" required />
          </div>
          <button class="btn btn-primary full-width" type="submit" id="loginBtn">Sign In</button>
        </form>

        <div class="auth-inline-link">
          <button type="button" class="link-button" id="showForgot">Forgot password?</button>
        </div>

        <div id="forgotPanel" class="auth-panel-inline hidden">
          <div class="auth-card__header">
            <h2>Forgot password</h2>
            <p>Request a reset link for your account.</p>
          </div>
          <div id="forgotError" class="alert alert-error hidden"></div>
          <div id="forgotSuccess" class="alert alert-success hidden"></div>
          <form id="forgotForm" class="auth-form">
            <div class="form-group">
              <label class="form-label">Email</label>
              <input class="form-input" type="email" name="email" placeholder="you@example.com" required />
            </div>
            <button class="btn btn-ghost full-width" type="submit">Send reset link</button>
          </form>
          <div class="form-help">You will receive a reset link if the email address exists.</div>
        </div>

        <div class="auth-divider"></div>

        <div class="auth-card__header">
          <h2>Create account</h2>
          <p>New here? Register and start splitting right away.</p>
        </div>
        <div id="regError" class="alert alert-error hidden"></div>
        <form id="registerForm" class="auth-form">
          <div class="form-group">
            <label class="form-label">Name</label>
            <input class="form-input" type="text" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input class="form-input" type="password" name="password" placeholder="Create a strong password" required />
          </div>
          <button class="btn btn-ghost full-width" type="submit">Create account</button>
        </form>
      </div>
    </section>
  </div>

  <script src="/js/app.js"></script>
  <script src="/js/auth.js"></script>
</body>
</html>
