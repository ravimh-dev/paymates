<%- include('../partials/page-head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>

  <div class="main-area">
    <main class="main-content main-content--wide">
      <div class="page-hero">
        <div>
          <p class="page-kicker">Workspace</p>
          <h1 class="page-title">Create Group</h1>
          <p class="page-sub">Start a new shared expense space.</p>
        </div>
        <a href="/groups" class="btn btn-ghost">Back to groups</a>
      </div>

      <section class="card card--soft form-shell">
        <div id="createGroupError" class="alert alert-error hidden"></div>
        <form id="createGroupForm" class="stack-form">
          <div class="form-group">
            <label class="form-label">Group Name</label>
            <input class="form-input" type="text" name="name" placeholder="Weekend Trip" required />
          </div>
          <div class="form-group">
            <label class="form-label">Description</label>
            <input class="form-input" type="text" name="description" placeholder="Optional description" />
          </div>
          <div class="form-group">
            <label class="form-label">Currency</label>
            <select class="form-input" name="currency">
              <option value="INR">INR</option>
              <option value="USD">USD</option>
              <option value="EUR">EUR</option>
              <option value="GBP">GBP</option>
            </select>
          </div>
          <div class="form-actions">
            <a href="/groups" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">Create group</button>
          </div>
        </form>
      </section>
    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<script src="/js/app.js"></script>
<script src="/js/create-group.js"></script>
</body>
</html>
