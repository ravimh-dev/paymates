<%- include('../partials/page-head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>

  <div class="main-area">
    <main class="main-content main-content--wide">
      <div class="page-hero">
        <div>
          <p class="page-kicker">Account</p>
          <h1 class="page-title">Profile</h1>
          <p class="page-sub">Manage your account, security, and preferences.</p>
        </div>
      </div>

      <div class="profile-grid">
        <section class="card card--soft form-shell">
          <div class="card-header-row">
            <div>
              <h2 class="card-title">Profile Details</h2>
              <p class="card-hint">Update your account details here.</p>
            </div>
          </div>
          <div id="profileError" class="alert alert-error hidden"></div>
          <form id="profileForm" class="stack-form">
            <div class="form-group">
              <label class="form-label">Name</label>
              <input class="form-input" type="text" name="name" id="profileName" required />
            </div>
            <div class="form-group">
              <label class="form-label">Avatar URL</label>
              <input class="form-input" type="url" name="avatar_url" id="profileAvatar" placeholder="https://..." />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Timezone</label>
                <input class="form-input" type="text" name="timezone" id="profileTimezone" placeholder="Asia/Calcutta" />
              </div>
              <div class="form-group">
                <label class="form-label">Currency</label>
                <input class="form-input" type="text" name="currency" id="profileCurrency" placeholder="INR" maxlength="3" />
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Save changes</button>
            </div>
          </form>
        </section>

        <section class="card card--soft form-shell">
          <div class="card-header-row">
            <div>
              <h2 class="card-title">Security</h2>
              <p class="card-hint">Manage your password and account status here.</p>
            </div>
          </div>
          <div id="passwordError" class="alert alert-error hidden"></div>
          <form id="passwordForm" class="stack-form">
            <div class="form-group">
              <label class="form-label">Current Password</label>
              <input class="form-input" type="password" name="currentPassword" required />
            </div>
            <div class="form-group">
              <label class="form-label">New Password</label>
              <input class="form-input" type="password" name="newPassword" required />
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Change password</button>
            </div>
          </form>

          <div class="divider"></div>

          <div id="deleteAccountError" class="alert alert-error hidden"></div>
          <p class="form-help">Deleting your account will deactivate your profile and clear your session.</p>
          <button type="button" class="btn btn-danger" id="deleteAccountBtn">Delete account</button>
        </section>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<script src="/js/app.js"></script>
<script src="/js/profile.js"></script>
</body>
</html>
