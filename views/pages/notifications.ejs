<%- include('../partials/page-head') %>
<div class="app-layout">
  <%- include('../partials/sidebar') %>

  <div class="main-area">
    <main class="main-content main-content--wide">
      <div class="page-hero">
        <div>
          <p class="page-kicker">Activity</p>
          <h1 class="page-title">Notifications</h1>
          <p class="page-sub">Track group invites, expense updates, and settlement reminders.</p>
        </div>
      </div>

      <div class="card card--soft">
        <div class="card-header-row">
          <div>
            <h2 class="card-title">Inbox</h2>
            <p class="card-hint"><span id="notificationUnreadCount">0</span> unread notifications.</p>
          </div>
          <div class="card-actions">
            <button type="button" class="btn btn-ghost btn-sm" id="refreshNotificationsBtn">Refresh</button>
            <button type="button" class="btn btn-primary btn-sm" id="markAllNotificationsBtn">Mark all read</button>
          </div>
        </div>

        <div id="notificationsError" class="alert alert-error hidden"></div>
        <div id="notificationsList" class="stack-list">
          <div class="empty-panel">Loading notifications...</div>
        </div>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

<script src="/js/app.js"></script>
<script src="/js/notifications.js"></script>
</body>
</html>
