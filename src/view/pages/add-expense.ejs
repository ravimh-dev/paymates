<div class="max-w-2xl mx-auto">
    <div class="mb-8">
        <a href="/groups/<%= groupId %>" class="text-indigo-600 font-medium flex items-center gap-1 mb-2 hover:underline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Back to Group
        </a>
        <h2 class="text-3xl font-bold">Add New Expense</h2>
    </div>

    <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm">
        <% if (error) { %>
            <div class="bg-red-50 text-red-600 p-3 rounded-lg mb-4 text-sm font-medium">
                <%= error %>
            </div>
        <% } %>

        <form action="/expenses/add" method="POST" class="space-y-6">
            <input type="hidden" name="groupId" value="<%= groupId %>">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">What was this for?</label>
                    <input type="text" name="description" required placeholder="e.g. Dinner, Movie, Rent" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition text-lg">
                </div>
                
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">How Much?</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">₹</span>
                        <input type="number" step="0.01" name="amount" required placeholder="0.00" class="w-full pl-9 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition text-lg font-bold">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Category</label>
                    <select name="category" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                        <option value="Food">Food & Drinks</option>
                        <option value="Travel">Travel</option>
                        <option value="Stay">Stay/Accommodation</option>
                        <option value="Entertainment">Entertainment</option>
                        <option value="Other" selected>Other</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Who Paid?</label>
                    <select name="payerId" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                        <% members.forEach(member => { %>
                            <option value="<%= member.id %>" <%= member.id === user.id ? 'selected' : '' %>><%= member.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-3 uppercase tracking-wide">Split With Anyone?</label>
                <div class="bg-slate-50 rounded-2xl p-4 border border-slate-200 space-y-3">
                    <% members.forEach(member => { %>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" name="participants" value="<%= member.id %>" checked class="w-5 h-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                            <span class="text-slate-700 group-hover:text-indigo-600 transition font-medium"><%= member.name %></span>
                        </label>
                    <% }) %>
                </div>
                <p class="text-[10px] text-slate-400 mt-2 uppercase font-bold tracking-widest">Expense will be split equally among selected members</p>
            </div>

            <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-bold text-lg hover:bg-slate-800 transition shadow-lg shadow-slate-200">
                Save Expense
            </button>
        </form>
    </div>
</div>
