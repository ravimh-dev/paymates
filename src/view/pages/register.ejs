<div class="max-w-md mx-auto bg-white p-8 rounded-2xl border border-slate-100 shadow-sm">
    <h2 class="text-2xl font-bold text-center mb-6">Create Account</h2>
    
    <% if (error) { %>
        <div class="bg-red-50 text-red-600 p-3 rounded-lg mb-4 text-sm font-medium">
            <%= error %>
        </div>
    <% } %>

    <form action="/auth/register" method="POST" class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
            <input type="text" name="name" required class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
        </div>
        <button type="submit" class="w-full bg-indigo-600 text-white py-2 rounded-lg font-semibold hover:bg-indigo-700 transition mt-6">
            Sign Up
        </button>
    </form>
    
    <p class="text-center text-slate-500 text-sm mt-6">
        Already have an account? <a href="/auth/login" class="text-indigo-600 font-medium hover:underline">Login here</a>
    </p>
</div>
