<div class="max-w-3xl mx-auto">
    <div class="mb-8">
        <a href="/groups/<%= group.id %>" class="text-indigo-600 font-medium flex items-center gap-1 mb-2 hover:underline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Back to Group
        </a>
        <h2 class="text-3xl font-bold">Intelligent Settlement Plan</h2>
        <p class="text-slate-500">We've calculated the most efficient way to settle all debts in <%= group.name %>.</p>
    </div>

    <% if (plan.length === 0) { %>
        <div class="bg-emerald-50 border border-emerald-100 p-12 rounded-3xl text-center">
            <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4 text-emerald-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <h3 class="text-xl font-bold text-emerald-900 mb-2">Everything is Square!</h3>
            <p class="text-emerald-700">No settlements needed at this time. All debts are cleared.</p>
        </div>
    <% } else { %>
        <div class="bg-white rounded-3xl border border-slate-200 shadow-xl shadow-slate-100 overflow-hidden">
            <div class="p-6 bg-slate-50 border-b border-slate-100">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest"><%= plan.length %> Recommended Transactions</span>
            </div>
            <div class="divide-y divide-slate-100">
                <% plan.forEach(step => { %>
                    <div class="p-8 flex flex-col md:flex-row items-center justify-between gap-6">
                        <div class="flex items-center gap-6 flex-1">
                            <div class="text-center">
                                <div class="w-14 h-14 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-xl mx-auto">
                                    <%= step.fromName.charAt(0) %>
                                </div>
                                <p class="text-sm font-bold mt-2"><%= step.fromName %></p>
                                <span class="text-[10px] uppercase font-bold text-slate-400">Debtor</span>
                            </div>

                            <div class="flex-grow flex flex-col items-center gap-2">
                                <div class="text-xl font-black text-indigo-600">₹<%= step.amount.toLocaleString() %></div>
                                <div class="w-full h-px bg-slate-200 relative">
                                    <div class="absolute right-0 top-1/2 -translate-y-1/2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300"><path d="m9 18 6-6-6-6"/></svg>
                                    </div>
                                </div>
                            </div>

                            <div class="text-center">
                                <div class="w-14 h-14 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-600 font-bold text-xl mx-auto">
                                    <%= step.toName.charAt(0) %>
                                </div>
                                <p class="text-sm font-bold mt-2"><%= step.toName %></p>
                                <span class="text-[10px] uppercase font-bold text-slate-400">Creditor</span>
                            </div>
                        </div>
                        
                        <div class="flex-shrink-0">
                            <form action="/settlements/mark-settled" method="POST">
                                <input type="hidden" name="groupId" value="<%= group.id %>">
                                <input type="hidden" name="payerId" value="<%= step.from %>">
                                <input type="hidden" name="payeeId" value="<%= step.to %>">
                                <input type="hidden" name="amount" value="<%= step.amount %>">
                                <button type="submit" class="bg-indigo-600 text-white px-6 py-2.5 rounded-xl font-bold hover:bg-indigo-700 transition shadow-sm">
                                    Mark as Paid
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
            <div class="p-6 bg-indigo-50 text-indigo-700 text-xs text-center font-medium">
                Tip: This plan uses a greedy flow-matching algorithm to minimize total payments.
            </div>
        </div>
    <% } %>
</div>
