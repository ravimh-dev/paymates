<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Group Details & Members -->
    <div class="lg:col-span-1 space-y-8">
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <a href="/groups" class="text-indigo-600 text-sm font-medium flex items-center gap-1 mb-4 hover:underline">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Back to Dashboard
            </a>
            <h2 class="text-2xl font-bold mb-2"><%= group.name %></h2>
            <p class="text-slate-500 text-sm"><%= group.description %></p>
            <div class="mt-4 pt-4 border-t border-slate-100 flex justify-between items-center">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Status</span>
                <span class="px-2 py-1 bg-indigo-50 text-indigo-600 text-xs font-bold rounded uppercase"><%= group.status %></span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="text-lg font-bold mb-4 flex items-center justify-between">
                Members
                <span class="text-sm font-medium text-slate-400"><%= members.length %></span>
            </h3>
            
            <div class="space-y-3 mb-6">
                <% members.forEach(member => { %>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-600">
                                <%= member.name.charAt(0) %>
                            </div>
                            <div>
                                <p class="text-sm font-semibold"><%= member.name %></p>
                                <p class="text-xs text-slate-400"><%= member.role %></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="pt-6 border-t border-slate-100">
                <h4 class="text-sm font-bold mb-3 uppercase tracking-wider text-slate-400">Invite Member</h4>
                <% if (error) { %>
                    <div class="text-red-500 text-xs mb-2"><%= error %></div>
                <% } %>
                <form action="/groups/<%= group.id %>/invite" method="POST" class="space-y-3">
                    <input type="email" name="email" placeholder="Email address" required class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                    <select name="role" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                        <option value="Member">Member</option>
                        <option value="Admin">Admin</option>
                        <option value="Viewer">Viewer</option>
                    </select>
                    <button type="submit" class="w-full bg-slate-900 text-white py-2 rounded-lg text-sm font-semibold hover:bg-slate-800 transition">
                        Add to Group
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Expenses & Settlements -->
    <div class="lg:col-span-2 space-y-8">
        <!-- Actions & Summary -->
        <div class="bg-indigo-600 p-8 rounded-3xl text-white shadow-xl shadow-indigo-100 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <p class="text-indigo-100 text-sm font-medium mb-1 uppercase tracking-wider">Group Balance</p>
                <h2 class="text-4xl font-bold">₹<%= expenses.reduce((acc, exp) => acc + exp.amount, 0).toLocaleString() %></h2>
                <p class="text-indigo-200 text-xs mt-1">Total group spending to date</p>
            </div>
            <div class="flex gap-3">
                <a href="/expenses/add?groupId=<%= group.id %>" class="bg-white text-indigo-600 px-6 py-3 rounded-xl font-bold hover:bg-indigo-50 transition shadow-lg shadow-indigo-900/10">
                    + Add Expense
                </a>
                <a href="/settlements/optimize/<%= group.id %>" class="bg-indigo-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-indigo-400 border border-indigo-400 transition shadow-lg shadow-indigo-900/10">
                    Settle Up
                </a>
            </div>
        </div>

        <!-- Expenses List -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                <h3 class="text-xl font-bold">Recent Expenses</h3>
                <a href="/expenses?groupId=<%= group.id %>" class="text-indigo-600 text-sm font-bold hover:underline">View All</a>
            </div>
            
            <% if (expenses.length === 0) { %>
                <div class="p-12 text-center text-slate-400">
                    <p>No expenses recorded yet.</p>
                </div>
            <% } else { %>
                <div class="divide-y divide-slate-100">
                    <% expenses.forEach(expense => { %>
                        <div class="p-6 hover:bg-slate-50 transition flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-slate-500">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="3" x2="21" y1="10" y2="10"/><line x1="7" x2="7" y1="2" y2="4"/><line x1="17" x2="17" y1="2" y2="4"/></svg>
                                </div>
                                <div>
                                    <h4 class="font-bold text-slate-900"><%= expense.description %></h4>
                                    <p class="text-xs text-slate-400">Paid by <span class="text-slate-600 font-medium"><%= expense.payer_name %></span> • <%= new Date(expense.expense_date).toLocaleDateString() %></p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-lg font-bold text-slate-900">₹<%= expense.amount.toLocaleString() %></p>
                                <span class="text-[10px] font-bold uppercase py-0.5 px-1.5 bg-slate-100 text-slate-500 rounded"><%= expense.category %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>
</div>
