<div class="flex items-center justify-between mb-8">
    <h2 class="text-3xl font-bold">Expenses</h2>
    <% if (groupId) { %>
        <a href="/expenses/add?groupId=<%= groupId %>" class="bg-indigo-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-indigo-700 transition">
            + Add Expense
        </a>
    <% } %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <% if (expenses.length === 0) { %>
        <div class="p-12 text-center text-slate-400">
            <p>No expenses found.</p>
        </div>
    <% } else { %>
        <table class="w-full text-left">
            <thead class="bg-slate-50 border-b border-slate-100">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Date</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Description</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Group</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Payer</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Amount</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% expenses.forEach(expense => { %>
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-6 py-4 text-sm text-slate-500"><%= new Date(expense.expense_date).toLocaleDateString() %></td>
                        <td class="px-6 py-4">
                            <div class="font-bold text-slate-900"><%= expense.description %></div>
                            <div class="text-[10px] text-slate-400 uppercase font-bold"><%= expense.category %></div>
                        </td>
                        <td class="px-6 py-4 text-sm font-medium text-indigo-600"><%= expense.group_name %></td>
                        <td class="px-6 py-4 text-sm text-slate-600"><%= expense.payer_name %></td>
                        <td class="px-6 py-4 text-right">
                            <span class="font-bold text-slate-900">₹<%= expense.amount.toLocaleString() %></span>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>
